{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "hooks/resolver/inject-resolver.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hooks/resolver/standing-order-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hooks/resolver/pre-action-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "hooks/resolver/think-gate-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/resolver/investigate-gate-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/bash/destructive-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/infrastructure/catalog-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/branch-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/no-attribution.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/ticket-required.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/no-sensitive-files.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/no-broad-staging.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/self-review.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/survey-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/detect-ai-fingerprints.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "hooks/git/post-error-revision-required.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/pre-push-self-review.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/git/pr-base-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/write/write-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/write/branch-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/write/ticket-propagation-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/write/write-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/write/branch-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "hooks/write/ticket-propagation-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__session__send_agent_message",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/agent-comms/no-slug-form-outbound.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
